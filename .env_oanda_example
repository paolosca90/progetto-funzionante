# OANDA API Configuration
# ========================

# OANDA API Credentials
# Get these from your OANDA account dashboard
OANDA_API_KEY=your_oanda_api_key_here
OANDA_ACCOUNT_ID=your_oanda_account_id_here

# OANDA Environment
# Use 'demo' for practice accounts, 'live' for real trading accounts
OANDA_ENVIRONMENT=demo

# Market Data Adapter Settings
# ============================

# Enable mock provider for testing (true/false)
ENABLE_MOCK_PROVIDER=false

# Provider priority order (comma-separated)
# Lower numbers = higher priority
MARKET_DATA_PROVIDERS=OANDA_Primary:1,MT5_Bridge:2,Mock_Testing:99

# Rate limiting settings
OANDA_RATE_LIMIT_PER_SECOND=100
OANDA_RATE_LIMIT_PER_MINUTE=6000

# Connection settings
OANDA_REQUEST_TIMEOUT=30
OANDA_MAX_RETRIES=3
OANDA_CIRCUIT_BREAKER_THRESHOLD=5

# Health monitoring
HEALTH_CHECK_INTERVAL=60

# Existing MT5 Bridge Configuration (fallback)
# ============================================
MT5_BRIDGE_URL=http://154.61.187.189:8000
BRIDGE_BASE_URL=http://154.61.187.189:8000

# Other existing configuration
# ===========================
GEMINI_API_KEY=your_gemini_api_key_here